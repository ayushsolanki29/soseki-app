{
  "name": "soseki-app",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "setup": "npm install && npm run setup:db",
    "setup:db": "npm --workspace backend run db:dev && npm --workspace backend run db:seed",
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace backend run build && npm --workspace frontend run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
